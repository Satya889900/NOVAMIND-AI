docker/
Dockerfile
docker-compose.yml

# Ignore OS metadata
.DS_Store
Thumbs.db

# Ignore version control metadata
.git
.gitignore
.gitattributes
.hg
.svn

# Ignore documentation and markdown files
README.md
Walkthrough.md
*.md
